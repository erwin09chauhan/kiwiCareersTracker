# Copy to .env for local development (docker-compose + dotnet run)

# Postgres
POSTGRES_DB=jobtracker
POSTGRES_USER=jobtracker
POSTGRES_PASSWORD=jobtracker

# RabbitMQ
RABBITMQ_DEFAULT_USER=jobtracker
RABBITMQ_DEFAULT_PASS=jobtracker

# --- ASP.NET Core config overrides (read via env vars with __ separator) ---
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=jobtracker;Username=jobtracker;Password=jobtracker
ConnectionStrings__Redis=localhost:6379

RabbitMq__Host=localhost
RabbitMq__Username=jobtracker
RabbitMq__Password=jobtracker

Jwt__Secret=CHANGE_ME_super_secret_key_min_32_chars_long_for_hmac_sha256
Jwt__Issuer=JobApplicationTracker
Jwt__Audience=JobApplicationTrackerClients

Cors__AllowedOrigins__0=http://localhost:3000
Cors__AllowedOrigins__1=http://localhost:5173
