{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=jobtracker;Username=jobtracker;Password=jobtracker",
    "Redis": "localhost:6379"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Username": "jobtracker",
    "Password": "jobtracker"
  },
  "RateLimiting": {
    "Limit": 100,
    "WindowSeconds": 60
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Jwt": {
    "Secret": "CHANGE_ME_super_secret_key_min_32_chars_long_for_hmac_sha256",
    "Issuer": "JobApplicationTracker",
    "Audience": "JobApplicationTrackerClients",
    "AccessTokenExpiryMinutes": 15
  },
  "ApplyMigrationsOnStartup": false,
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  }
}

